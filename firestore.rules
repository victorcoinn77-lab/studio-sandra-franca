rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email == "victor.coinn77@gmail.com";
    }

    match /appointments/{appointmentId} {
      allow read: if request.auth != null && request.auth.token.email == "victor.coinn77@gmail.com";
      allow create: if true;
      allow update, delete: if request.auth != null && request.auth.token.email == "victor.coinn77@gmail.com";
    }
  }
}
